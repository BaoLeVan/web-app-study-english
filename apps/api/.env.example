# API
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Database
DATABASE_URL="postgresql://linguoflow:linguoflow@localhost:5432/linguoflow?schema=public"

# Auth
JWT_SECRET="dev-secret-change-me"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Object storage (MinIO dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=linguoflow

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@linguoflow.app

# Speech assessment uses the Web Speech API in-browser — no server-side key needed.
